# ── Claude API (Primary LLM) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI API (Fallback LLM) ─────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://syl:syl_dev_password@localhost:5432/syl_db
DATABASE_URL_SYNC=postgresql://syl:syl_dev_password@localhost:5432/syl_db

# ── Qdrant ────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Redis (Response Cache) ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Auth ──────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_minimum_32_chars
JWT_EXPIRY_DAYS=7

# ── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── FastAPI Service ───────────────────────────────────────────
API_URL=http://localhost:8000
API_SECRET_KEY=change_me_in_production

# ── Go Orchestrator ───────────────────────────────────────────
ORCHESTRATOR_URL=http://localhost:8080

# ── Next.js ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# ── Embedding Model ───────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── File Storage ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=100

# ── Environment ───────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=debug
